#!/bin/sh
# Инвариант проекта: sidebar-toggle.js не должен содержать символа "меньше".
# Поле ввода JS в ЛК checker-soft обрезает содержимое на первом таком символе
# (принимает его за начало HTML-тега) — файл с ним доедет до продакшена
# обрезанным, и половина функций молча исчезнет.
#
# Раньше инвариант держался только на ручной проверке после каждой правки.
# Хук ставится так (core.hooksPath версионируется вместе с репо):
#   git config core.hooksPath .githooks
#
# Обойти осознанно (например, правится только README): git commit --no-verify

set -e

FILE="sidebar-toggle.js"
[ -f "$FILE" ] || exit 0

n=$(grep -c '<' "$FILE" || true)
if [ "$n" -ne 0 ]; then
  echo "❌ pre-commit: в $FILE найден символ «меньше» ($n шт.) — поле ЛК обрежет файл!"
  echo "   Строки:"
  grep -n '<' "$FILE" | sed 's/^/     /'
  echo "   В комментариях пишите «тег table» / «элемент form», в коде — обходите"
  echo "   через !== / .slice() (см. примеры в шапке файла)."
  exit 1
fi

exit 0
